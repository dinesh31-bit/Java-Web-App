properties([pipelineTriggers([githubPush()])])
node{
    def mavenHome= tool name: 'Maven 3.9.12', type: 'maven'
    def tomcat_ip = '13.235.94.162'
    stage("git clone"){
         git brach: 'main', credentialsId:'dinesh31bitgit', url:'https://github.com/dinesh31-bit/Java-Web-App.git'
     }
    stage("maven clean package"){
        sh "${mavenHome}/bin/mvn clean package"
    }
    stage("maven celan verify"){
        withCredentials([string(credentialsId: 'SonarQube', variable: 'sonar_qube')]) {
            sh "${mavenHome}/bin/mvn clean verify sonar:sonar -Dsonar.token=${sonar_qube}"
        }
    }
    stage("maven clean deploy"){
        sh "${mavenHome}/bin/mvn clean deploy"
    }
    stage("deploy to tomcat"){
        sh "echo 'deploy to tomcat'"
        sshagent(['tomcat-shh-credentials']) {
            sh """
                ssh -o strichtHostKeyChecking=no ec2-user@${tomcat_ip} sudo systemctl stop tomcat
                ssh -o strichtHostKeyChecking=no ec2-user@${tomcat_ip} rm -f /opt/tomcat/webapps/java-web-app-1.0.war
                scp -o strichtHostKeyChecking=no target/java-web-app-1.0.war ec2-user@${tomcat_ip}:/opt/tomcat/webapps/java-web-app-1.0.war
                ssh -o strichtHostKeyChecking=no ec2-user@${tomcat_ip} sudo systemctl start tomcat
            """
        }
    }
}